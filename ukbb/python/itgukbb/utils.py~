import os
import sys

def readConfig(fname):
    C=dict()
    if os.path.exists(fname):
        with open(fname,"r") as f:
            for line in f:
                l=line.rstrip()
                if l and not l.startswith("#"):
                    x=l.split("\t",1)
                    C[x[0]]=x[1]
        return C
    else:
        print("ERROR: config file %s does not exist" % fname,file=sys.stderr)
        return None


